digraph ISM {
  graph [rankdir=BT, labelloc="t", label="ISM hierarchy"];
  node [shape=box, style="rounded,filled", fillcolor="#f7f7f7"];
  edge [color="#555555"];
  "需求" [xlabel="L5"];
  "设计" [xlabel="L4"];
  "采购" [xlabel="L3"];
  "制造" [xlabel="L2"];
  "测试" [xlabel="L1"];
  "需求" -> "设计";
  "设计" -> "采购";
  "设计" -> "制造";
  "采购" -> "制造";
  "制造" -> "测试";
  { rank=same; "测试"; }
  { rank=same; "制造"; }
  { rank=same; "采购"; }
  { rank=same; "设计"; }
  { rank=same; "需求"; }
}
